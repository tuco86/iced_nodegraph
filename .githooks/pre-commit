#!/usr/bin/env bash
# Fast gate: mirror the CI format check so an unformatted commit never lands.
# Fix with `cargo fmt --all`, then re-stage.
set -euo pipefail

if ! cargo fmt --all -- --check; then
    echo
    echo "pre-commit: rustfmt found unformatted code (see diff above)."
    echo "  run: cargo fmt --all   then re-stage and commit."
    exit 1
fi
